      "source": [
        "encabezado(2, 'Retencion de nitrogeno en franja riberena', C2)\n",
        "\n",
        "x = sp.symbols('x', nonnegative=True)\n",
        "R = sp.Rational(84,100)*x / (1 + sp.Rational(4,100)*x**2)**2\n",
