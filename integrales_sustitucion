        "import numpy as np\n",
        "import sympy as sp\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.gridspec as gridspec\n",
        "from matplotlib.ticker import AutoMinorLocator\n",
        "from IPython.display import display, Math, HTML\n",
        "\n",
        "sp.init_printing(use_latex='mathjax')\n",
        "\n",
        "# Paleta ambiental\n",
        "C1, C2, C3 = '#2e86c1', '#27ae60', '#8e44ad'\n",
        "F1, F2, F3 = '#aed6f1', '#a9dfbf', '#d7bde2'\n",
        "NARANJA = '#e67e22'\n",
        "\n",
        "plt.rcParams.update({\n",
        "    'figure.facecolor': 'white', 'axes.facecolor': '#f8f9fa',\n",
        "    'axes.grid': True, 'grid.color': 'white', 'grid.linewidth': 1.3,\n",
        "    'axes.spines.top': False, 'axes.spines.right': False,\n",
        "    'font.family': 'DejaVu Sans', 'font.size': 11,\n",
        "    'axes.titlesize': 12, 'axes.titleweight': 'bold',\n",
        "    'legend.framealpha': 0.9,\n",
        "})\n",
        "\n",
        "def val(expr, dec=3):\n",
        "    return round(float(sp.N(expr)), dec)\n",
        "\n",
        "def graficar_ejemplo(var, expr, a, b, titulo, xlabel, ylabel,\n",
        "                     color, fill, unidad='', resultado=None, n=600):\n",
        "    f = sp.lambdify(var, expr, modules=['numpy'])\n",
        "    xs = np.linspace(float(a), float(b), n)\n",
        "    ys = f(xs)\n",
        "    cumsum = np.zeros_like(xs)\n",
        "    for i in range(1, n):\n",
        "        cumsum[i] = cumsum[i-1] + 0.5*(ys[i]+ys[i-1])*(xs[i]-xs[i-1])\n",
        "\n",
        "    fig = plt.figure(figsize=(12, 5), layout='constrained')\n",
        "    gs  = gridspec.GridSpec(1, 2, figure=fig, wspace=0.38)\n",
        "    ax1 = fig.add_subplot(gs[0])\n",
        "    ax2 = fig.add_subplot(gs[1])\n",
        "\n",
        "    ax1.fill_between(xs, ys, alpha=0.28, color=fill)\n",
        "    ax1.plot(xs, ys, color=color, linewidth=2.6, label='f(x)', zorder=3)\n",
        "    ax1.axhline(0, color='#aaa', linewidth=0.8)\n",
        "    idx = int(np.argmax(ys))\n",
        "    ax1.plot(xs[idx], ys[idx], 'o', color=NARANJA, markersize=9, zorder=5,\n",
        "             label=f'Max: ({xs[idx]:.2f}, {ys[idx]:.2f})')\n",
        "    ax1.axvline(float(a), color='#777', linestyle=':', linewidth=1.2)\n",
        "    ax1.axvline(float(b), color='#777', linestyle=':', linewidth=1.2)\n",
        "    ymin = min(ys)*0.05 + min(ys)\n",
        "    ax1.text(float(a), ymin, f' a={a}', va='bottom', fontsize=9, color='#555')\n",
        "    ax1.text(float(b), ymin, f' b={b}', va='bottom', fontsize=9, color='#555')\n",
        "    ax1.set_title('Funcion integrando', pad=8)\n",
        "    ax1.set_xlabel(xlabel); ax1.set_ylabel(ylabel)\n",
        "    ax1.legend(fontsize=9)\n",
        "    ax1.xaxis.set_minor_locator(AutoMinorLocator())\n",
        "\n",
        "    ax2.fill_between(xs, cumsum, alpha=0.22, color=fill)\n",
        "    ax2.plot(xs, cumsum, color=color, linewidth=2.6)\n",
        "    if resultado is not None:\n",
        "        ax2.axhline(resultado, color=NARANJA, linestyle='--', linewidth=1.6)\n",
        "        ax2.text(xs[n//2], resultado*1.06,\n",
        "                 f'Total = {resultado} {unidad}',\n",
        "                 ha='center', fontsize=10, color=NARANJA, fontweight='bold')\n",
        "    ax2.set_title('Area acumulada', pad=8)\n",
        "    ax2.set_xlabel(xlabel)\n",
        "    ax2.set_ylabel(f'Acumulado [{unidad}]' if unidad else 'Acumulado')\n",
        "    ax2.xaxis.set_minor_locator(AutoMinorLocator())\n",
        "\n",
        "    fig.suptitle(titulo, fontsize=13, fontweight='bold')\n",
        "    plt.show()\n",
        "\n",
        "def info_box(titulo, contenido, color='#2e86c1', emoji='i'):\n",
        "    display(HTML(\n",
        "        '<div style=\"background:' + color + '12;border-left:5px solid ' + color + ';'\n",
        "        'border-radius:8px;padding:14px 18px;margin:12px 0;font-family:Segoe UI,sans-serif;\">'\n",
        "        '<strong style=\"color:' + color + ';font-size:1.05em;\">' + emoji + ' ' + titulo + '</strong>'\n",
        "        '<div style=\"margin-top:8px;color:#2c3e50;line-height:1.75;\">' + contenido + '</div></div>'\n",
        "    ))\n",
        "\n",
        "def encabezado(n, nombre, color):\n",
        "    display(HTML(\n",
        "        '<div style=\"background:' + color + ';border-radius:10px;padding:14px 22px;'\n",
        "        'margin:24px 0 10px;font-family:Segoe UI,sans-serif;color:white;\">'\n",
        "        '<span style=\"font-size:1.4em;font-weight:700;\">Ejemplo ' + str(n) + '</span>'\n",
        "        '<span style=\"font-size:1.1em;margin-left:14px;opacity:.92;\">'\n",
        "        + nombre + '</span></div>'\n",
        "    ))\n",
        "\n",
        "print('Configuracion lista.')"
